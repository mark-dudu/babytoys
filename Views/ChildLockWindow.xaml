<Window x:Class="BabyToys.Views.ChildLockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Black">
  <Grid x:Name="Root" Background="Black">
    <Image x:Name="DisplayImage" Stretch="UniformToFill" Opacity="1" />
    <Rectangle x:Name="DimOverlay" Fill="#CC000000" />
    <Rectangle x:Name="BlackOverlay" Fill="Black" Opacity="0" />
    <Border x:Name="StatusPanel"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="24"
            Padding="14,10"
            Background="#99000000"
            CornerRadius="6">
      <StackPanel>
        <TextBlock x:Name="RemainingText"
                   Foreground="#DDFFFFFF"
                   FontSize="16"
                   TextAlignment="Right" />
        <TextBlock x:Name="UnlockText"
                   Foreground="#FFFFFFFF"
                   FontSize="14"
                   Margin="0,6,0,0"
                   Text="正在解锁..."
                   Visibility="Collapsed" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
