<Window x:Class="BabyToys.Views.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BabyToys 诊断"
        Width="680"
        Height="600"
        MinWidth="560"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI"
        Background="#F4F6F8">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="运行诊断" FontSize="26" FontWeight="SemiBold" />
      <TextBlock Text="以下信息不包含具体按键或输入内容。"
                 Margin="0,5,0,14"
                 Foreground="#596675" />
    </StackPanel>

    <TextBox x:Name="ReportTextBox"
             Grid.Row="1"
             Padding="14"
             IsReadOnly="True"
             TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Disabled"
             FontFamily="Consolas"
             FontSize="13"
             Background="White"
             BorderBrush="#D8DEE7" />

    <Grid Grid.Row="2" Margin="0,14,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock x:Name="StatusTextBlock"
                 VerticalAlignment="Center"
                 Foreground="#596675" />
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button Content="打开日志" Padding="16,8" Click="OpenLogsButton_Click" />
        <Button Content="复制报告" Margin="10,0,0,0" Padding="16,8" Click="CopyButton_Click" />
        <Button Content="刷新" Margin="10,0,0,0" Padding="16,8" Click="RefreshButton_Click" />
        <Button Content="关闭" Margin="10,0,0,0" Padding="16,8" IsCancel="True" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
