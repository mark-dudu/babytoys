<Window x:Class="BabyToys.Views.EntryConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Black"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
  <Grid Background="Black">
    <Border x:Name="ConfirmationPanel"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="28"
            Padding="16,13"
            Background="#FF080808"
            BorderBrush="#FF242424"
            BorderThickness="1"
            CornerRadius="6">
      <StackPanel>
        <TextBlock x:Name="CountdownText"
                   Foreground="#FF929292"
                   FontFamily="Microsoft YaHei UI"
                   FontSize="14"
                   TextAlignment="Right" />
        <TextBlock Text="按 Esc 或点击取消"
                   Margin="0,4,0,10"
                   Foreground="#FF686868"
                   FontFamily="Microsoft YaHei UI"
                   FontSize="12"
                   TextAlignment="Right" />
        <Button x:Name="CancelButton"
                Content="取消"
                Width="84"
                Height="30"
                HorizontalAlignment="Right"
                FocusVisualStyle="{x:Null}"
                Foreground="#FFB0B0B0"
                Background="#FF111111"
                BorderBrush="#FF343434"
                BorderThickness="1"
                Click="CancelButton_Click">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border x:Name="ButtonBorder"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="4">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="#FF181818" />
                  <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF484848" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="#FF222222" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </StackPanel>
    </Border>
  </Grid>
</Window>
