<Window x:Class="BabyToys.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BabyToys 儿童模式"
        Width="640"
        Height="620"
        MinWidth="600"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI">
  <Window.Resources>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2933" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#596675" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8DEE7" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1E40AF" />

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style TargetType="RadioButton">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="Button">
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentPressedBrush}" />
                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentPressedBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Root" Property="Background" Value="#9CA3AF" />
                <Setter TargetName="Root" Property="BorderBrush" Value="#9CA3AF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#F8FAFC" />
                <Setter TargetName="Root" Property="BorderBrush" Value="#C7D0DC" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel>
        <TextBlock Text="BabyToys"
                 FontSize="30"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextPrimaryBrush}" />
        <TextBlock Text="儿童模式防误触"
                   Margin="0,6,0,0"
                   FontSize="15"
                   Foreground="{StaticResource TextSecondaryBrush}" />
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
        <Button Content="诊断"
                Height="30"
                Padding="12,0"
                Margin="0,0,10,0"
                Click="DiagnosticsButton_Click" />
        <Border Padding="10,6"
                Background="#EEF2FF"
                BorderBrush="#C7D2FE"
                BorderThickness="1"
                CornerRadius="6">
          <TextBlock x:Name="VersionTextBlock"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#3730A3" />
        </Border>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1"
            Margin="0,20,0,18"
            Padding="22"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Border Padding="14"
                  Background="#F8FAFC"
                  BorderBrush="#E2E8F0"
                  BorderThickness="1"
                  CornerRadius="6">
            <StackPanel>
              <TextBlock Text="覆盖所有屏幕，降低误触和屏幕吸引力。"
                         FontSize="15"
                         FontWeight="SemiBold" />
              <TextBlock Text="解锁方式：长按 Ctrl + Alt + U 3 秒。"
                         Margin="0,5,0,0"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}" />
              <TextBlock Text="这不是安全锁屏；Ctrl + Alt + Del、电源键和系统安全桌面仍可用于恢复。"
                         Margin="0,3,0,0"
                         Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
          </Border>

          <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Text="进入画面" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Text="优先让电脑迅速变得无趣，减少宝宝继续拍打键鼠的兴趣。"
                       Margin="0,4,0,8"
                       Style="{StaticResource MutedTextStyle}" />
            <RadioButton x:Name="ImmediateBlackRadio"
                         Content="立即黑屏（推荐）"
                         GroupName="EntryVisual"
                         IsChecked="True"
                         Checked="ImageSource_Checked" />
            <RadioButton x:Name="FadeFromImageRadio"
                         Content="短暂显示图片，10 秒后渐暗"
                         GroupName="EntryVisual"
                         Checked="ImageSource_Checked" />

            <StackPanel x:Name="ImageSourcePanel" Margin="20,8,0,0">
              <RadioButton x:Name="SystemWallpaperRadio"
                           Content="使用系统壁纸"
                           GroupName="ImageSource"
                           IsChecked="True"
                           Checked="ImageSource_Checked" />
              <RadioButton x:Name="CustomImageRadio"
                           Content="使用自定义图片"
                           GroupName="ImageSource"
                           Checked="ImageSource_Checked" />

              <DockPanel Margin="0,10,0,0">
                <Button x:Name="ChooseImageButton"
                        Content="选择图片"
                        Style="{StaticResource SecondaryButtonStyle}"
                        DockPanel.Dock="Right"
                        Click="ChooseImageButton_Click" />
                <TextBox x:Name="CustomImagePathTextBox"
                         Margin="0,0,10,0"
                         IsReadOnly="True" />
              </DockPanel>
            </StackPanel>
          </StackPanel>

          <Separator Grid.Row="2" Margin="0,18,0,18" Background="#E5EAF1" />

          <StackPanel Grid.Row="3">
            <TextBlock Text="时间限制" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Text="到达时间后会释放输入拦截并请求系统睡眠。可输入 0.5 到 240 分钟。"
                       Margin="0,4,0,0"
                       Style="{StaticResource MutedTextStyle}" />
            <StackPanel Orientation="Horizontal"
                        Margin="0,10,0,0">
              <TextBox x:Name="DurationTextBox"
                       Width="120"
                       Text="5" />
              <TextBlock Text="分钟"
                         VerticalAlignment="Center"
                         Margin="10,0,0,0"
                         Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
          </StackPanel>

          <Separator Grid.Row="4" Margin="0,18,0,18" Background="#E5EAF1" />

          <StackPanel Grid.Row="5">
            <TextBlock Text="显示选项" Style="{StaticResource SectionTitleStyle}" />
            <CheckBox x:Name="ShowCountdownCheckBox"
                      Content="儿童模式中显示倒计时"
                      Margin="0,10,0,0"
                      VerticalAlignment="Center" />
          </StackPanel>

          <Separator Grid.Row="6" Margin="0,18,0,18" Background="#E5EAF1" />

          <StackPanel Grid.Row="7">
            <TextBlock Text="快捷与常驻" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Text="保存常用组合，并从托盘或快捷键快速启动。"
                       Margin="0,4,0,8"
                       Style="{StaticResource MutedTextStyle}" />
            <DockPanel>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,0,0,0">
                <Button Content="保存预设"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SavePresetButton_Click" />
                <Button Content="删除"
                        Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="DeletePresetButton_Click" />
              </StackPanel>
              <ComboBox x:Name="PresetComboBox"
                        Height="36"
                        Padding="8,0"
                        IsEditable="True"
                        VerticalContentAlignment="Center"
                        SelectionChanged="PresetComboBox_SelectionChanged" />
            </DockPanel>
            <CheckBox x:Name="EnableGlobalHotKeyCheckBox"
                      Content="启用 Ctrl + Alt + B 快速启动"
                      Margin="0,12,0,0"
                      Click="OptionCheckBox_Click" />
            <CheckBox x:Name="StartWithWindowsCheckBox"
                      Content="登录 Windows 后自动启动到托盘"
                      Margin="0,10,0,0"
                      Click="OptionCheckBox_Click" />
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Name="StatusTextBlock"
                 VerticalAlignment="Center"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 FontSize="13"
                 Text="准备就绪" />

      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button x:Name="CancelCountdownButton"
                Content="取消"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,0,10,0"
                Visibility="Collapsed"
                Click="CancelCountdownButton_Click" />
        <Button x:Name="StartButton"
                Content="进入儿童模式"
                MinWidth="150"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="StartButton_Click" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
